{
	"name": "jgg11ty",
	"version": "2.0.0",
	"type": "module",
	"description": "Joel Goodman's personal blog.",
	"repository": "https://github.com/joelgoodman/jggweb",
	"scripts": {
		"build:js": "rollup -c",
		"watch:js": "rollup -c --watch",
		"start": "cross-env ELEVENTY_ENV=development npm-run-all2 build:js --parallel watch:js watch:eleventy",
		"watch:eleventy": "eleventy --serve",
		"debug:start": "DEBUG=Eleventy* npm start",
		"build": "cross-env ELEVENTY_ENV=production npm-run-all2 build:js build:eleventy",
		"build:eleventy": "eleventy",
		"clean": "rm -rf _site",
		"debug:build": "DEBUG=Eleventy* npm run build",
		"deploy": "npm run clean && npm run build && node scripts/upload-to-bunny.js"
	},
	"keywords": [
		"blog",
		"eleventy"
	],
	"author": "Joel G Goodman",
	"license": "ISC",
	"devDependencies": {
		"@11ty/eleventy": "^3.0.0",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-plugin-rss": "^2.0.2",
		"@fullhuman/postcss-purgecss": "^6.0.0",
		"@rollup/plugin-node-resolve": "^16.0.0",
		"@rollup/plugin-terser": "^0.4.4",
		"autoprefixer": "^10.4.20",
		"clean-css": "^5.3.3",
		"cross-env": "^7.0.3",
		"cssnano": "^7.0.0",
		"eleventy-plugin-embed-everything": "^1.19.0",
		"html-minifier-terser": "^7.2.0",
		"luxon": "^3.5.0",
		"markdown-it": "^14.1.0",
		"npm-run-all2": "^7.0.0",
		"postcss": "^8.4.49",
		"postcss-cli": "^11.0.0",
		"purgecss": "^6.0.0",
		"rollup": "^4.28.0",
		"sass": "^1.82.0",
		"terser": "^5.36.0"
	},
	"dependencies": {
		"dotenv": "^17.3.1",
		"upload-to-bunny": "^2.1.1"
	}
}