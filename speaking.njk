---
title: Speaking Engagements / Joel G Goodman
layout: layouts/base.njk
pageType: feature
section: speaking
slug: speaking
---

{# Image Panel gallery — the year-groups below map into these photos
   by position (auto-distributed at build time). When we add an image
   field to the Pages CMS collection we can lift this into a data file. #}
{% set speakingGallery = [
  { src: 'ggrgt.jpg', alt: 'Speaking with conference presenters at Aggregate Conference' },
  { src: 'heweb-sketch.jpg', alt: 'Leading a design workshop in a conference room' },
  { src: 'heweb4.jpg', alt: 'Speaking at a conference with arms wide' },
  { src: 'heweb5.jpg', alt: 'Speaking with arms raised at 90 degrees like the chicken dance' }
] %}

<div class="content-column">
  <nav class="rail" id="rail-content" aria-label="Site navigation">
    {% include "components/rail.njk" %}
  </nav>

  <main class="detail" id="main" tabindex="-1">
    <button class="detail__tab" id="detail-tab" aria-expanded="true" aria-controls="detail-content" aria-label="Toggle details"></button>
    {% include "components/slide-panels.njk" %}

    <div class="detail__content" id="detail-content">
      <div class="detail__slide">
        <header>
          <p class="detail__eyebrow">Speaking</p>
          <h1 class="detail__title">Speaking Engagements</h1>
          <p class="detail__summary">That undergrad Communication degree really came in handy when I started speaking at conferences in 2011. From Portland, OR to London, UK, my presentations and workshops have ranged from a deep dive into Sass to how to draw inspiration for better higher ed web design.</p>
        </header>

        <section class="events-list detail__body">
          {% set yearGroups = collections.speaking_event | groupByYear %}
          {% set groupCount = yearGroups.length %}
          {% set photoCount = speakingGallery.length %}
          {% for group in yearGroups %}
            {# Auto-distribute year-groups across gallery photos so the
               image panel crossfades through the four photos as the
               reader scrolls. floor(idx * photoCount / groupCount),
               capped at photoCount - 1 to guard against integer drift. #}
            {% set photoIdx = (loop.index0 * photoCount / groupCount) | int %}
            {% if photoIdx >= photoCount %}{% set photoIdx = photoCount - 1 %}{% endif %}
            <section class="year-group" data-photo="{{ photoIdx }}">
              <h2 class="year-group__heading">{{ group.year }}</h2>
              {% for event in group.items %}
                <article class="event">
                  <h3>{{ event.data.title }}</h3>
                  <p>
                    <time class="byline-meta-date">{{ event.data.date | monthYearDate }}</time>
                    &mdash;
                    {% if event.data.event_url %}<a href="{{ event.data.event_url }}">{{ event.data.event_name }}</a>{% else %}{{ event.data.event_name }}{% endif %}
                    {% if event.data.role %} &mdash; {{ event.data.role }}{% endif %}
                  </p>
                </article>
              {% endfor %}
            </section>
          {% endfor %}
        </section>
      </div>
    </div>
  </main>
</div>

{# ── JSON-LD: ItemList of Events ──────────────────────
   Every speaking engagement on the page gets its own Event entity so
   AI answer engines (and Google rich results) can enumerate talks by
   year, venue, and topic. The whole thing is wrapped in an ItemList
   for page-level context. `location.name` uses the event_name verbatim
   since many include the city inline ("HighEdWeb Buffalo, NY") and a
   separate structured city rarely parses cleanly from venue strings. #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Speaking engagements by Joel Goodman",
  "numberOfItems": {{ collections.speaking_event.length }},
  "itemListElement": [
    {% for event in collections.speaking_event | reverse %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "item": {
        "@type": "Event",
        "name": {{ event.data.title | dump | safe }},
        "startDate": "{{ event.data.date.toISOString().slice(0, 10) }}",
        "eventStatus": "https://schema.org/EventScheduled",
        {% if event.data.event_url %}"url": "{{ event.data.event_url }}",{% endif %}
        "location": {
          "@type": "Place",
          "name": {{ event.data.event_name | dump | safe }}
        },
        "organizer": {
          "@type": "Organization",
          "name": {{ event.data.event_name | dump | safe }}{% if event.data.event_url %},
          "url": "{{ event.data.event_url }}"{% endif %}
        },
        "performer": {
          "@type": "Person",
          "name": {{ metadata.author.name | dump | safe }},
          "url": "{{ metadata.url }}"
        }{% if event.data.role %},
        "@additionalType": {{ event.data.role | dump | safe }}{% endif %}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

{# Image Panel — single full-bleed photo that crossfades to a new one
   as you scroll into different year ranges. #}
<section class="image-panel" id="image-panel" aria-label="Speaking moments">
  <div class="image-panel__slide" id="image-slide">
    {% for photo in speakingGallery %}
      <img class="speaking-cover{% if loop.first %} speaking-cover--current is-active{% endif %}"
           data-photo="{{ loop.index0 }}"
           src="/assets/img/{{ photo.src }}"
           alt="{{ photo.alt }}"
           loading="eager"
           {% if loop.first %}fetchpriority="high"{% else %}aria-hidden="true"{% endif %}
           sizes="(max-width: 768px) 100vw, 50vw" />
    {% endfor %}
  </div>
</section>
