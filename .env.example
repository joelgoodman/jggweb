# Site Configuration
SITE_URL=https://joelgoodman.co

# Bunny.net Storage — used by scripts/upload-to-bunny.js
# Storage zone name: found in Bunny dashboard → Storage → your zone name
# API key: found in Storage zone → FTP & API Access → Password
BUNNY_STORAGE_ZONE=your-storage-zone-name
BUNNY_API_KEY=your-storage-zone-password
