---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
    {% for item in collections.all %}
        {# Skip collection items without their own URL (permalink: false)
           — speaking_events and similar list-only entries. #}
        {% if item.url and item.url !== false %}
        <url>
            <loc>{{ item.url | url | absoluteUrl(metadata.url) }}</loc>
            <lastmod>{{ item.date.toISOString() }}</lastmod>
        </url>
        {% endif %}
    {% endfor %}
</urlset>
