{# ── SEO cascade resolution ────────────────────────────────
   All fallbacks live here so the <title>, meta tags, and JSON-LD
   pull from the same resolved values. Overrides flow:
     seo.*  (per-entry, CMS-editable)
        ↓
     title / excerpt / summary / cover.*  (frontmatter)
        ↓
     content (first paragraph extracted from rendered HTML)
        ↓
     metadata.*  (_data/metadata.json site defaults)
── #}

{# Title: seo.title wins; else compose clean title + site suffix #}
{% set _baseTitle = seo.title or title %}
{% if _baseTitle %}
  {% set pageTitle = _baseTitle + (metadata.title_suffix or '') %}
{% else %}
  {% set pageTitle = metadata.title + ' — ' + metadata.subtitle %}
{% endif %}

{# Description: seo → excerpt → summary → first paragraph → site default.
   Always run through metaDescription so HTML in summary / first
   paragraph doesn't leak into social card attributes, and so length
   stays under the ~160-char display ceiling. #}
{% set _rawDescription = seo.description or excerpt or summary or (content | firstParagraphText) or metadata.description %}
{% set pageDescription = _rawDescription | metaDescription %}

{# Social image: seo.image → cover.image → metadata default.
   Accepts bare filenames (prepended with /assets/img/) or absolute paths. #}
{% if seo.image %}
  {% if (seo.image | startsWith('/')) or (seo.image | startsWith('http')) %}
    {% set _img = seo.image %}
  {% else %}
    {% set _img = '/assets/img/' + seo.image %}
  {% endif %}
{% elif cover.image %}
  {% if (cover.image | startsWith('/')) or (cover.image | startsWith('http')) %}
    {% set _img = cover.image %}
  {% else %}
    {% set _img = '/assets/img/' + cover.image %}
  {% endif %}
{% else %}
  {% set _img = metadata.og_image %}
{% endif %}
{% set socialImage = _img | toAbsolute(metadata.url) %}
{% set socialImageAlt = seo.image_alt or cover.alt or metadata.og_image_alt %}

{# Canonical URL: seo.canonical wins but is normalized to absolute
   in case the author entered a relative path. #}
{% if seo.canonical %}
  {% set canonicalUrl = seo.canonical | toAbsolute(metadata.url) %}
{% else %}
  {% set canonicalUrl = page.url | url | absoluteUrl(metadata.url) %}
{% endif %}

{# Robots: only emit override if non-default. #}
{% set robotsDirective = seo.robots or metadata.robots_default %}

{# OG type: letters are Articles, the home is a Profile (it renders a
   Person JSON-LD entity), everything else is a WebPage. Detect letters
   by URL prefix since section/pageType aren't reliable on all
   collection items. #}
{% set isLetter = (page.url | startsWith('/letters/')) and page.url != '/letters/' %}
{% set isHome = page.url == '/' %}
{% if isLetter %}
  {% set ogType = 'article' %}
{% elif isHome %}
  {% set ogType = 'profile' %}
{% else %}
  {% set ogType = 'website' %}
{% endif %}

<head>
  <meta charset="utf-8">
  <script>
    (function(){var t=localStorage.getItem('theme')||(matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');document.documentElement.setAttribute('data-theme',t);})();
  </script>
  <script type="speculationrules">
  {
    "prerender": [{
      "where": {
        "and": [
          { "href_matches": "/*" },
          { "not": { "href_matches": "/feed/*" } },
          { "not": { "href_matches": "/assets/*" } },
          { "not": { "selector_matches": "[rel~=external]" } }
        ]
      },
      "eagerness": "moderate"
    }]
  }
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />

  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}">
  <meta name="robots" content="{{ robotsDirective }}">
  <meta name="generator" content="Eleventy">
  <link rel="canonical" href="{{ canonicalUrl }}">

  {% if site.environment === 'production' %}
  <link rel="preload" href="/assets/fonts/PlusJakartaSans-VariableFont_wght-subset.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/assets/fonts/InstrumentSerif-Regular-subset.woff2" as="font" type="font/woff2" crossorigin>
  {% endif %}

  <link rel="webmention" href="https://webmention.io/joelgoodman.co/webmention" />
  <link rel="pingback" href="https://webmention.io/joelgoodman.co/xmlrpc" />
  <link rel="alternate" type="application/atom+xml" title="Atom feed for joelgoodman.co" href="/feed/atom.xml" />

  <link rel="icon" href="/assets/icons/favicon.svg" type="image/svg+xml">
  <link rel="mask-icon" href="/assets/icons/safari-pinned-tab.svg" color="#011936">

  {# ── Open Graph ─────────────────────────────── #}
  <meta property="og:site_name" content="{{ metadata.title }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ canonicalUrl }}">
  <meta property="og:type" content="{{ ogType }}">
  <meta property="og:image" content="{{ socialImage }}">
  <meta property="og:image:alt" content="{{ socialImageAlt }}">
  <meta property="og:locale" content="{{ metadata.locale }}">
  {% if isLetter %}
    <meta property="article:section" content="Letters">
    {% if date_published %}<meta property="article:published_time" content="{{ date_published | htmlDateString }}">{% endif %}
    {% if date_updated %}<meta property="article:modified_time" content="{{ date_updated | htmlDateString }}">{% endif %}
    <meta property="article:author" content="{{ metadata.url }}">
    {% for tag in tags | tagList %}
      <meta property="article:tag" content="{{ tag }}">
    {% endfor %}
  {% endif %}

  {# ── Twitter Card ───────────────────────────── #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@{{ metadata.author.social.twitter }}">
  <meta name="twitter:creator" content="@{{ metadata.author.social.twitter }}">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ socialImage }}">
  <meta name="twitter:image:alt" content="{{ socialImageAlt }}">

  {# ── JSON-LD ─────────────────────────────────
     BlogPosting for letters (+ BreadcrumbList in a second script tag),
     WebPage for pages, and a rich Person snippet on the home. Kept
     raw so PurgeCSS/htmlmin don't fight the JSON payload.
     GEO notes: BlogPosting is the Schema.org subclass most AI answer
     engines weight higher for editorial content; the Person schema
     on the home is the entity-disambiguation anchor (same name +
     description + sameAs crosslinks = "this is one person across
     the web"). #}
  {% if isLetter %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": {{ (seo.title or title) | dump | safe }},
    "description": {{ pageDescription | dump | safe }},
    "image": {
      "@type": "ImageObject",
      "url": "{{ socialImage }}",
      "caption": {{ (socialImageAlt or "") | dump | safe }}
    },
    "datePublished": "{% if date_published %}{{ date_published | htmlDateString }}{% endif %}",
    "dateModified": "{% if date_updated %}{{ date_updated | htmlDateString }}{% elif date_published %}{{ date_published | htmlDateString }}{% endif %}",
    "author": {
      "@type": "Person",
      "name": {{ metadata.author.name | dump | safe }},
      "url": "{{ metadata.url }}"
    },
    "publisher": {
      "@type": "Person",
      "name": {{ metadata.author.name | dump | safe }},
      "url": "{{ metadata.url }}"
    },
    "mainEntityOfPage": "{{ canonicalUrl }}"{% if tags %},
    "keywords": {{ tags | dump | safe }}{% endif %}{% if tldr %},
    "abstract": {{ tldr | dump | safe }}{% endif %}
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "{{ metadata.url }}"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Letters",
        "item": "{{ metadata.url }}#letters"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": {{ (seo.title or title) | dump | safe }},
        "item": "{{ canonicalUrl }}"
      }
    ]
  }
  </script>
  {% elif page.url == '/' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": {{ metadata.author.name | dump | safe }},
    "description": {{ metadata.description | dump | safe }},
    "url": "{{ metadata.url }}",
    "image": "{{ socialImage }}",
    "jobTitle": {{ metadata.author.job_title | dump | safe }},
    "homeLocation": {
      "@type": "Place",
      "name": {{ metadata.author.location | dump | safe }}
    },
    "worksFor": {
      "@type": "Organization",
      "name": {{ metadata.author.works_for.name | dump | safe }},
      "url": "{{ metadata.author.works_for.url }}"
    },
    "knowsAbout": {{ metadata.author.knows_about | dump | safe }},
    "sameAs": {{ metadata.author.same_as | dump | safe }}
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": {{ pageTitle | dump | safe }},
    "description": {{ pageDescription | dump | safe }},
    "url": "{{ canonicalUrl }}",
    "image": "{{ socialImage }}"
  }
  </script>
  {% endif %}

  {% if site.environment === 'production' %}
    <!-- INLINE CSS-->
  {% else %}
    <link rel="stylesheet" href="/assets/css/jgg.css">
  {% endif %}
  <!-- Privacy-friendly analytics by Plausible -->
  <script async src="https://plausible.io/js/pa-nR-AEaMNu_DnhM18eiRlu.js"></script>
  <script>
    window.plausible = window.plausible || function() { (plausible.q = plausible.q || []).push(arguments) }, plausible.init = plausible.init || function(i) { plausible.o = i || {} };
    plausible.init()
  </script>
</head>
