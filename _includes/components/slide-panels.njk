{# Slide panels — rendered inside .detail on letter pages and home.
   Letters list panel uses the same pattern as HEHT's episode list. #}

{# Letters list overlay — reverse-chronological (newest first) #}
<div class="letter-list-panel"
     id="letter-list-panel"
     aria-hidden="true">
  <button class="slide-panel__close" id="letter-list-close" aria-label="Close">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <div class="letter-list-panel__header">
    <h2 class="letter-list-panel__title">All Letters</h2>
  </div>
  <nav class="letter-list-panel__list" role="navigation" aria-label="Letter navigation">
    {% set letters = collections.letter | reverse %}
    {% set currentYear = "" %}
    {% for letter in letters %}
      {% set letterYear = letter.date | yearDate %}
      {% if letterYear != currentYear %}
        {% set currentYear = letterYear %}
        <span class="letter-list-panel__year">{{ letterYear }}</span>
      {% endif %}
      <a href="{{ letter.url | url }}" class="letter-list-panel__item"{% if letter.url === page.url %} aria-current="page"{% endif %}>
        <span class="letter-list-panel__name">{{ letter.data.title }}</span>
        <span class="letter-list-panel__date">{{ letter.date | readableDate }}</span>
      </a>
    {% endfor %}
  </nav>
</div>
