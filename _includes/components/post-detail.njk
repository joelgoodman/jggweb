{# Post Detail — renders inside the .detail panel for letter pages.
   Adapted from HEHT's episode-detail for blog post content. #}

<div class="detail__slide" id="detail-slide">
  <p class="detail__eyebrow">
    <span>{{ date_published | readableDate }}</span>
  </p>

  <h1 class="detail__title">{{ title }}</h1>

  <div class="detail__meta">
    <span>Joel Goodman</span>
    <span>{{ content | readingTime }} read</span>
  </div>

  {% if excerpt %}
  <p class="detail__summary">{{ excerpt }}</p>
  {% endif %}

  <div class="detail__body">
    {{ content | safe }}
  </div>

  {% include "components/post-nav.njk" %}
</div>
