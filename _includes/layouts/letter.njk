---
layout: layouts/base.njk
pageType: letter
---

{# ── Content Column (rail + detail) ───────────────────── #}
<div class="content-column">
  <nav class="rail" aria-label="Site navigation">
    {% include "components/rail.njk" %}
  </nav>

  <article class="detail" id="main" tabindex="-1">
    <button class="detail__tab" id="detail-tab" aria-expanded="true" aria-controls="detail-content" aria-label="Toggle post details"></button>

    {% include "components/slide-panels.njk" %}

    <div class="detail__content" id="detail-content">
      {% include "components/post-detail.njk" %}
    </div>
  </article>
</div>

{# ── Image Panel (cover image where HEHT's video panel was) ── #}
<section class="image-panel" id="image-panel" aria-label="Post cover image">
  <div class="image-panel__slide" id="image-slide"{% if cover.image %} style="background-image:url('{% lqip cover.image %}')"{% endif %}>
    {% if cover.image %}
    <img
      src="/assets/img/{{ cover.image }}"
      alt="{{ cover.alt }}"
      class="image-panel__cover"
      loading="eager"
      fetchpriority="high"
      sizes="(max-width: 1024px) 100vw, 50vw" />
    {% endif %}
  </div>

  <nav class="letter-nav" aria-label="Letter navigation">
    <button id="prev-btn" type="button" aria-label="Previous letter">←</button>
    <button id="next-btn" type="button" aria-label="Next letter">→</button>
  </nav>
</section>
