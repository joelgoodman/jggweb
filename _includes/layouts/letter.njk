---
layout: layouts/base.njk
pageType: letter
---

{# ── Content Column (rail + detail) ───────────────────── #}
<div class="content-column">
  <nav class="rail" aria-label="Site navigation">
    {% include "components/rail.njk" %}
  </nav>

  <article class="detail" id="main" tabindex="-1">
    <button class="detail__tab" id="detail-tab" aria-expanded="true" aria-controls="main" aria-label="Toggle post details"></button>

    {% include "components/slide-panels.njk" %}

    <div class="detail__content" id="detail-content">
      {% include "components/post-detail.njk" %}
    </div>
  </article>
</div>

{# ── Image Panel (cover image where HEHT's video panel was) ── #}
{% if cover.image %}
<section class="image-panel" id="image-panel" aria-label="Post cover image">
  <img
    src="/assets/img/{{ cover.image }}"
    alt="{{ cover.alt }}"
    class="image-panel__cover" />
</section>
{% endif %}
